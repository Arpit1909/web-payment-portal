# ===== SERVER =====
PORT=5000
NODE_ENV=development

# ===== JWT =====
JWT_SECRET=change_this_to_a_strong_random_secret

# ===== ADMIN CREDENTIALS =====
ADMIN_USERNAME=admin@example.com
ADMIN_DEFAULT_PASSWORD=changeme

# ===== TELEGRAM =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_CHANNEL_URL=https://t.me/your_channel
TELEGRAM_ADMIN_ID=

# ===== INSTAMOJO PAYMENT GATEWAY =====
# Sandbox: https://test.instamojo.com/api/1.1
# Production: https://www.instamojo.com/api/1.1
INSTAMOJO_API_KEY=
INSTAMOJO_AUTH_TOKEN=
INSTAMOJO_BASE_URL=https://test.instamojo.com/api/1.1

# ===== BACKEND URL (for webhooks) =====
BACKEND_URL=http://localhost:5000

# ===== DATABASE =====
DB_PATH=./database.sqlite

# ===== CORS =====
FRONTEND_URL=http://localhost:5173
